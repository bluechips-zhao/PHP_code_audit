{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Correlation Report",
  "description": "Cross-auditor correlation analysis report output by correlation-engine",
  "type": "object",
  "required": [
    "generated_at",
    "total_findings",
    "false_positives_removed",
    "chains",
    "summary"
  ],
  "properties": {
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "total_findings": {
      "type": "integer"
    },
    "false_positives_removed": {
      "type": "integer"
    },
    "chains": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "chain_id",
          "vulns",
          "combined_impact",
          "confidence"
        ],
        "properties": {
          "chain_id": {
            "type": "string",
            "pattern": "^CHAIN-\\d{1,4}$",
            "maxLength": 12
          },
          "vulns": {
            "type": "array",
            "items": {
              "type": "string",
              "maxLength": 1000,
              "minLength": 1
            }
          },
          "combined_impact": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high",
              "critical"
            ]
          },
          "confidence": {
            "type": "string",
            "enum": [
              "high",
              "medium",
              "low"
            ]
          },
          "description": {
            "type": "string",
            "maxLength": 2000,
            "minLength": 1
          }
        }
      }
    },
    "second_order_vulns": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "summary": {
      "type": "string",
      "maxLength": 3000,
      "minLength": 1
    },
    "graph_correlations": {
      "type": "object",
      "description": "Relational memory graph consumption results (rule category 4.5 output)",
      "properties": {
        "data_flow_chains": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "source_node": {
                "type": "string",
                "pattern": "^[A-Za-z0-9_-]+$",
                "maxLength": 100
              },
              "target_node": {
                "type": "string",
                "pattern": "^[A-Za-z0-9_-]+$",
                "maxLength": 100
              },
              "relation": {
                "type": "string",
                "enum": [
                  "auth_bypass",
                  "privilege_escalation",
                  "data_flow",
                  "credential_reuse",
                  "session_hijack",
                  "token_forge",
                  "file_access",
                  "code_execution",
                  "information_disclosure",
                  "resource_access",
                  "chained_exploit"
                ]
              },
              "source_status": {
                "type": "string",
                "enum": [
                  "confirmed",
                  "suspected",
                  "not_vulnerable",
                  "failed",
                  "error",
                  "skipped"
                ]
              },
              "target_status": {
                "type": "string",
                "enum": [
                  "confirmed",
                  "suspected",
                  "not_vulnerable",
                  "failed",
                  "error",
                  "skipped"
                ]
              },
              "escalated_severity": {
                "type": "string",
                "enum": [
                  "low",
                  "medium",
                  "high",
                  "critical"
                ]
              }
            }
          },
          "description": "Data flow attack chains discovered via data_flows_to edges"
        },
        "reassessment_candidates": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "node_id": {
                "type": "string",
                "maxLength": 150,
                "minLength": 1
              },
              "sink_id": {
                "type": "string",
                "pattern": "^[A-Za-z0-9_-]+$",
                "maxLength": 100
              },
              "reason": {
                "type": "string",
                "maxLength": 500,
                "minLength": 1
              },
              "enabled_by": {
                "type": "string",
                "maxLength": 1000,
                "minLength": 1
              }
            }
          },
          "description": "Sinks requiring reassessment due to satisfied prerequisites"
        },
        "escalations_from_graph": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "source_node": {
                "type": "string",
                "pattern": "^[A-Za-z0-9_-]+$",
                "maxLength": 100
              },
              "target_node": {
                "type": "string",
                "pattern": "^[A-Za-z0-9_-]+$",
                "maxLength": 100
              },
              "original_severities": {
                "type": "array",
                "items": {
                  "type": "string",
                  "maxLength": 1000,
                  "minLength": 1
                }
              },
              "combined_severity": {
                "type": "string",
                "maxLength": 1000,
                "minLength": 1
              }
            }
          },
          "description": "Combined severity escalations based on escalates_to edges"
        },
        "high_value_targets": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "data_object",
              "vuln_count"
            ],
            "properties": {
              "data_object": {
                "type": "string",
                "maxLength": 1000,
                "minLength": 1
              },
              "vuln_count": {
                "type": "integer",
                "minimum": 3
              },
              "vuln_types": {
                "type": "array",
                "items": {
                  "type": "string",
                  "maxLength": 1000,
                  "minLength": 1
                }
              },
              "max_severity": {
                "type": "string",
                "maxLength": 1000,
                "minLength": 1
              },
              "recommendation": {
                "type": "string",
                "maxLength": 500,
                "minLength": 1
              }
            }
          },
          "description": "High-value targets with ≥3 vulnerabilities on the same data object"
        },
        "historical_pattern_matches": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "pattern": {
                "type": "string",
                "maxLength": 1000,
                "minLength": 1
              },
              "matched_from_project": {
                "type": "string",
                "maxLength": 1000,
                "minLength": 1
              },
              "suggestion": {
                "type": "string",
                "maxLength": 500,
                "minLength": 1
              }
            }
          },
          "description": "Cross-project historical pattern matches"
        }
      }
    }
  }
}
