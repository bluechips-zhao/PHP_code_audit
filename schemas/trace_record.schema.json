{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Trace Record",
  "description": "Trace record: call chain / dynamic bindings / request-response / error points",
  "type": "object",
  "required": [
    "route_id",
    "route_url",
    "call_chain",
    "filters_encountered",
    "dynamic_bindings",
    "raw_request",
    "raw_response_status"
  ],
  "properties": {
    "route_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_/-]+$",
      "maxLength": 100
    },
    "route_url": {
      "type": "string",
      "maxLength": 500,
      "minLength": 1
    },
    "call_chain": {
      "type": "array",
      "items": {
        "type": "string",
        "maxLength": 1000,
        "minLength": 1
      }
    },
    "filters_encountered": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "function",
          "effective",
          "reason"
        ],
        "properties": {
          "function": {
            "type": "string",
            "pattern": "^[a-zA-Z_\\\\][a-zA-Z0-9_\\\\:]*$",
            "maxLength": 200
          },
          "effective": {
            "type": "boolean"
          },
          "reason": {
            "type": "string",
            "maxLength": 500,
            "minLength": 1
          }
        }
      }
    },
    "dynamic_bindings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "type",
          "resolved"
        ],
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "call_user_func",
              "variable_method",
              "dynamic_include"
            ]
          },
          "resolved": {
            "type": "string",
            "maxLength": 500,
            "minLength": 1
          }
        }
      }
    },
    "raw_request": {
      "type": "string",
      "maxLength": 1000,
      "minLength": 1
    },
    "raw_response_status": {
      "type": "integer"
    },
    "error_point": {
      "type": [
        "string",
        "null"
      ]
    },
    "error_vs_sink": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "before_sink",
        "after_sink",
        null
      ]
    }
  }
}
