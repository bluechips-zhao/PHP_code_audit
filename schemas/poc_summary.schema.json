{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PoC Summary",
  "description": "PoC script summary output by Phase-4.5 poc_generator",
  "type": "object",
  "required": [
    "generated_at",
    "total_confirmed",
    "poc_generated",
    "scripts"
  ],
  "properties": {
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "total_confirmed": {
      "type": "integer"
    },
    "poc_generated": {
      "type": "integer"
    },
    "poc_skipped": {
      "type": "integer"
    },
    "scripts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "sink_id",
          "vuln_type",
          "file"
        ],
        "properties": {
          "sink_id": {
            "type": "string",
            "pattern": "^[A-Za-z0-9_-]+$",
            "maxLength": 100
          },
          "vuln_type": {
            "type": "string",
            "enum": [
              "sqli",
              "xss_ssti",
              "rce",
              "lfi",
              "filewrite",
              "ssrf",
              "xxe",
              "deserial",
              "crlf",
              "ldap",
              "nosql",
              "csrf",
              "session",
              "authz",
              "crypto",
              "race_condition",
              "business_logic",
              "infoleak",
              "logging",
              "config",
              "wordpress"
            ]
          },
          "file": {
            "type": "string",
            "description": "PoC script filename",
            "maxLength": 500,
            "minLength": 1
          },
          "endpoint": {
            "type": "string",
            "maxLength": 500,
            "minLength": 1
          },
          "auth_required": {
            "type": "boolean"
          },
          "curl_command": {
            "type": "string",
            "description": "Equivalent curl command",
            "maxLength": 5000,
            "minLength": 1
          }
        }
      }
    }
  }
}
