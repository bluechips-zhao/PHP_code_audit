{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Dependency Risk",
  "description": "Dependency risk: package / version / CVE / severity / fix version",
  "type": "array",
  "items": {
    "type": "object",
    "required": [
      "package",
      "installed_version",
      "cve",
      "severity",
      "type",
      "description",
      "fixed_version"
    ],
    "properties": {
      "package": {
        "type": "string",
        "maxLength": 200,
        "minLength": 1
      },
      "installed_version": {
        "type": "string",
        "pattern": "^[\\d\\.]+.*$",
        "maxLength": 50
      },
      "cve": {
        "type": "string",
        "pattern": "^CVE-\\d{4}-\\d{4,}$",
        "maxLength": 20
      },
      "severity": {
        "type": "string",
        "enum": [
          "CRITICAL",
          "HIGH",
          "MEDIUM",
          "LOW"
        ]
      },
      "type": {
        "type": "string",
        "maxLength": 100,
        "minLength": 1
      },
      "description": {
        "type": "string",
        "maxLength": 2000,
        "minLength": 1
      },
      "fixed_version": {
        "type": "string",
        "pattern": "^[\\d\\.]+.*$",
        "maxLength": 50
      }
    }
  }
}
