{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Auth Credentials",
  "description": "Authentication credentials and role matrix generated by Phase-3 auth_simulator",
  "type": "object",
  "required": [
    "generated_by",
    "credentials"
  ],
  "properties": {
    "generated_by": {
      "type": "string",
      "const": "auth_simulator"
    },
    "credentials": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "role",
          "auth_method"
        ],
        "properties": {
          "role": {
            "type": "string",
            "description": "Role name: admin/editor/subscriber/anonymous",
            "maxLength": 50,
            "minLength": 1
          },
          "username": {
            "type": "string",
            "maxLength": 100,
            "minLength": 1
          },
          "password": {
            "type": "string",
            "maxLength": 200,
            "minLength": 1
          },
          "token": {
            "type": "string",
            "description": "JWT/session token",
            "maxLength": 2000,
            "minLength": 1
          },
          "auth_method": {
            "type": "string",
            "enum": [
              "cookie",
              "bearer",
              "basic",
              "api_key"
            ]
          },
          "permissions": {
            "type": "array",
            "items": {
              "type": "string",
              "maxLength": 1000,
              "minLength": 1
            }
          }
        }
      }
    },
    "role_hierarchy": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": {
          "type": "string",
          "maxLength": 1000,
          "minLength": 1
        }
      }
    },
    "test_matrix": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "action",
          "endpoint"
        ],
        "properties": {
          "action": {
            "type": "string",
            "maxLength": 200,
            "minLength": 1
          },
          "endpoint": {
            "type": "string",
            "maxLength": 500,
            "minLength": 1
          },
          "expected_roles": {
            "type": "array",
            "items": {
              "type": "string",
              "maxLength": 1000,
              "minLength": 1
            }
          },
          "test_with_roles": {
            "type": "array",
            "items": {
              "type": "string",
              "maxLength": 1000,
              "minLength": 1
            }
          }
        }
      }
    }
  }
}
