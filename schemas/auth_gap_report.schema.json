{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Auth Gap Report",
  "description": "Route security gap report output by Phase-2 route_mapper",
  "type": "object",
  "required": [
    "generated_by",
    "total_routes",
    "unprotected_routes",
    "summary"
  ],
  "properties": {
    "generated_by": {
      "type": "string",
      "const": "route_mapper"
    },
    "total_routes": {
      "type": "integer"
    },
    "unprotected_routes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path",
          "method",
          "risk_level"
        ],
        "properties": {
          "path": {
            "type": "string",
            "description": "Route path",
            "maxLength": 500,
            "minLength": 1
          },
          "method": {
            "type": "string",
            "description": "HTTP method",
            "maxLength": 10,
            "minLength": 1
          },
          "controller": {
            "type": "string",
            "description": "Controller#method",
            "maxLength": 300,
            "minLength": 1
          },
          "missing_middleware": {
            "type": "array",
            "items": {
              "type": "string",
              "maxLength": 1000,
              "minLength": 1
            }
          },
          "risk_level": {
            "type": "string",
            "enum": [
              "high",
              "medium",
              "low"
            ]
          }
        }
      }
    },
    "summary": {
      "type": "object",
      "required": [
        "total_unprotected"
      ],
      "properties": {
        "total_unprotected": {
          "type": "integer"
        },
        "high_risk_count": {
          "type": "integer"
        }
      }
    }
  }
}
