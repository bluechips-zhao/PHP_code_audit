{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Shared Finding Entry",
  "description": "Single record of real-time shared findings between Phase-4 specialists (one per JSONL line)",
  "type": "object",
  "required": [
    "timestamp",
    "source_agent",
    "finding_type",
    "priority",
    "data"
  ],
  "properties": {
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "source_agent": {
      "type": "string",
      "description": "Source agent name (writer)",
      "maxLength": 100,
      "minLength": 1
    },
    "finding_type": {
      "type": "string",
      "enum": [
        "credential",
        "internal_url",
        "secret_key",
        "endpoint",
        "bypass_method",
        "config_value"
      ]
    },
    "priority": {
      "type": "string",
      "enum": [
        "critical",
        "high",
        "medium"
      ]
    },
    "data": {
      "type": "object",
      "required": [
        "key",
        "value"
      ],
      "properties": {
        "key": {
          "type": "string",
          "description": "Finding name/identifier",
          "maxLength": 200,
          "minLength": 1
        },
        "value": {
          "type": "string",
          "description": "Finding value",
          "maxLength": 2000,
          "minLength": 1
        },
        "context": {
          "type": "string",
          "description": "Context description of the finding",
          "maxLength": 2000,
          "minLength": 1
        },
        "source_location": {
          "type": "string",
          "description": "Finding source file:line",
          "maxLength": 500,
          "minLength": 1
        }
      }
    },
    "target_agents": {
      "type": "array",
      "items": {
        "type": "string",
        "maxLength": 1000,
        "minLength": 1
      },
      "description": "Suggested consumer agent names"
    },
    "consumed_by": {
      "type": "array",
      "items": {
        "type": "string",
        "maxLength": 1000,
        "minLength": 1
      },
      "description": "Agent names that consumed this finding"
    }
  }
}
